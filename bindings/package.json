{
  "name": "@rustcn/core",
  "version": "0.1.0",
  "description": "Core bindings for rustcn WASM engines",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./detection": {
      "import": "./dist/detection.js",
      "types": "./dist/detection.d.ts"
    },
    "./threshold": {
      "import": "./dist/threshold.js",
      "types": "./dist/threshold.d.ts"
    },
    "./fallbacks": {
      "import": "./dist/fallbacks/index.js",
      "types": "./dist/fallbacks/index.d.ts"
    },
    "./wasm": {
      "import": "./dist/wasm/index.js",
      "types": "./dist/wasm/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {},
  "license": "MIT"
}
